# 应用配置
APP_NAME=LLM Investment Analysis Platform
APP_ENV=development
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@db:5432/investment_db
REDIS_URL=redis://redis:6379/0

# LLM 配置（LiteLLM 统一接口）
DEEPSEEK_V4_API_KEY=your_deepseek_api_key
DEEPSEEK_R1_API_KEY=your_deepseek_api_key
OPENAI_API_KEY=your_openai_api_key

# 默认模型路由
DEFAULT_MODEL=deepseek-v4
CHINA_MODEL=deepseek-v4
US_MODEL=gpt-4o
REASONING_MODEL=deepseek-r1

# 飞书 Bot 配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token
FEISHU_BOT_PORT=8001

# 数据源配置
AKSHARE_RATE_LIMIT=3.0
FINNHUB_API_KEY=your_finnhub_api_key
COINGECKO_API_KEY=your_coingecko_api_key

# 缓存配置（秒）
CACHE_TTL_DAY_K=86400
CACHE_TTL_MACRO=604800
CACHE_TTL_FUND_FLOW=14400
CACHE_TTL_SENTIMENT=3600
CACHE_TTL_NEWS=1800
