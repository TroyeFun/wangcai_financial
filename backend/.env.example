# ============================================================
# LLM 投资分析平台 - 环境变量配置
# ============================================================
# 复制此文件为 .env，然后填入你的配置
# cp .env.example .env
# ============================================================

# ========== 应用配置 ==========
APP_NAME=LLM Investment Analysis Platform
APP_ENV=development
DEBUG=true

# ========== 服务器配置 ==========
HOST=0.0.0.0
PORT=8000

# ========== 数据库配置 ==========
DATABASE_URL=postgresql://postgres:postgres@db:5432/investment_db
REDIS_URL=redis://redis:6379/0

# ============================================================
# LLM 配置（重要！必填一项）
# ============================================================

# ---------- 方案一：AIHubMix（推荐国内用户）----------
# 官网：https://aihubmix.com
# 优势：国内直连、价格低、支持多模型、统一计费
AIHUBMIX_API_KEY=your_aihubmix_api_key_here
# 可选，自定义端点（不填则使用官方默认）
# AIHUBMIX_BASE_URL=https://api.aihubmix.com/v1

# ---------- 方案二：DeepSeek 官方 ----------
# 官网：https://platform.deepseek.com
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------- 方案三：OpenAI ----------
# 官网：https://platform.openai.com
# OPENAI_API_KEY=your_openai_api_key_here

# ---------- 方案四：Azure OpenAI ----------
# AZURE_API_KEY=your_azure_api_key_here
# AZURE_BASE_URL=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-01

# ============================================================
# 模型路由配置
# ============================================================
# AIHubMix 支持的模型别名：
# - deepseek-chat (DeepSeek V3，性价比最高)
# - deepseek-reasoner (DeepSeek R1，复杂推理)
# - gpt-4o (GPT-4o)
# - gpt-4o-mini (GPT-4o Mini)
# - qwen-plus (通义千问 Plus)
# - qwen-max (通义千问 Max)
# - yi-large (零一万物)
# - glm-4 (智谱 GLM-4)
# - moonshot-v1-8k (月之暗面 Moonshot)

DEFAULT_MODEL=deepseek-chat
CHINA_MODEL=deepseek-chat
US_MODEL=gpt-4o
REASONING_MODEL=deepseek-reasoner

# ============================================================
# 飞书 Bot 配置
# ============================================================
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token
FEISHU_BOT_PORT=8001

# ============================================================
# 数据源配置
# ============================================================
# AkShare（免费，无需配置）
AKSHARE_RATE_LIMIT=3.0

# Finnhub（美股，免费版 60req/min）
# 申请地址：https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# CoinGecko（加密货币，免费版 30req/min）
# 申请地址：https://www.coingecko.com/
COINGECKO_API_KEY=your_coingecko_api_key_here

# ============================================================
# 缓存配置（秒）
# ============================================================
CACHE_TTL_DAY_K=86400
CACHE_TTL_MACRO=604800
CACHE_TTL_FUND_FLOW=14400
CACHE_TTL_SENTIMENT=3600
CACHE_TTL_NEWS=1800
