# Copy to .env.compose and use:
#   docker compose --env-file .env.compose up -d --build
#
# This file is ONLY for Compose variable substitution (image names / build args).
# It does NOT replace backend/.env (app secrets stay there).

# --- Default: empty = use Docker Hub official names (needs reachable Docker Hub) ---

# --- China: pull images from a mirror registry (no Docker Hub auth) ---
# Try one prefix at a time; if one fails, switch to another.
#
# DaoCloud mirror (common for library/*):
DOCKER_POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:15-alpine
DOCKER_REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.10-slim
NODE_BASE_IMAGE=docker.m.daocloud.io/library/node:18-alpine

# Aliyun (alternative; replace lines above if DaoCloud is slow):
# DOCKER_POSTGRES_IMAGE=registry.cn-hangzhou.aliyuncs.com/library/postgres:15-alpine
# DOCKER_REDIS_IMAGE=registry.cn-hangzhou.aliyuncs.com/library/redis:7-alpine
# PYTHON_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/library/python:3.10-slim
# NODE_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/library/node:18-alpine

# pip / npm inside image build (China networks):
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
